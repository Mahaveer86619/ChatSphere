<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/chatsphere_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/chatsphere_icon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChatSphere"
        tools:targetApi="31">
        <activity
            android:name=".Screens.ChatScreen"
            android:exported="false" />
        <activity
            android:name=".Screens.LandingScreen"
            android:exported="false" />
        <activity
            android:name=".Screens.SignInScreen"
            android:exported="false" />
        <activity
            android:name=".Screens.LoginScreen"
            android:exported="false" />
        <activity
            android:name=".Screens.SplashScreen"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>